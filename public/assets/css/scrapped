.card {
    width:160px;
    background:var(--pallet2);
    border-radius:6px;
    overflow:hidden;
    cursor:pointer;
    display:flex;
    align-items:flex-end;
    justify-content:center;
    position:relative;
    border:2px solid transparent;
    transition:border 0.2s, transform 0.2s;
    gap:10px;
}